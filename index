<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>My Pocket</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  /* Orange palette */
  --o50:#FFF8F1;--o100:#FFEDD8;--o200:#FED7AA;--o300:#FDBA74;
  --o400:#FB923C;--o500:#F97316;--o600:#EA6500;--o700:#C2500A;
  --o800:#9A3E08;

  /* Neutrals */
  --w:#FFFFFF;--n50:#FAFAF9;--n100:#F5F3EF;--n150:#EEEAE3;
  --n200:#E2DBD0;--n300:#C5BAA8;--n400:#9A8F80;--n500:#6B6055;
  --n600:#4A4138;--n700:#302920;--n800:#1C1410;

  /* Status */
  --g50:#F0FDF4;--g100:#DCFCE7;--g400:#4ADE80;--g500:#22C55E;--g600:#16A34A;
  --r50:#FFF1F2;--r100:#FFE4E6;--r400:#F87171;--r500:#EF4444;--r600:#DC2626;
  --b50:#EFF6FF;--b100:#DBEAFE;--b500:#3B82F6;--b600:#2563EB;
  --v50:#F5F3FF;--v100:#EDE9FE;--v500:#8B5CF6;--v600:#7C3AED;

  --rad-xs:6px;--rad-s:10px;--rad-m:16px;--rad-l:22px;--rad-xl:28px;
  --sh-xs:0 1px 3px rgba(28,20,16,.06);
  --sh-s:0 2px 10px rgba(28,20,16,.08);
  --sh-m:0 6px 24px rgba(28,20,16,.10);
  --sh-l:0 16px 48px rgba(28,20,16,.14);
}

*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
body{font-family:'Manrope',sans-serif;background:var(--n100);color:var(--n800);max-width:430px;margin:0 auto;height:100%;display:flex;flex-direction:column;position:relative;}

.scroller{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;padding-bottom:96px;}

/* ── Topbar ── */
.topbar{background:var(--w);border-bottom:1.5px solid var(--n150);padding:13px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:50;}
.logo{font-family:'Clash Display',sans-serif;font-size:19px;font-weight:700;letter-spacing:-.3px;color:var(--n800);}
.logo span{color:var(--o600);}
.mpill{display:flex;align-items:center;gap:3px;background:var(--n100);border-radius:99px;padding:5px 6px 5px 14px;border:1.5px solid var(--n200);}
.mpill-txt{font-size:12px;font-weight:700;color:var(--n600);min-width:72px;text-align:center;letter-spacing:-.1px;}
.mpill-btn{width:28px;height:28px;border-radius:50%;background:var(--w);border:1.5px solid var(--n200);cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:var(--sh-xs);}
.mpill-btn:active{background:var(--n100);}
.mpill-btn svg{width:9px;height:9px;stroke:var(--n400);stroke-width:2.5;fill:none;stroke-linecap:round;stroke-linejoin:round;}

/* ── Bottom Nav ── */
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:var(--w);border-top:1.5px solid var(--n150);display:flex;padding:9px 0 20px;z-index:100;}
.btab{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;border:none;background:none;cursor:pointer;padding:2px 0;font-family:'Manrope',sans-serif;}
.btab-ico svg{width:20px;height:20px;stroke:var(--n300);stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round;transition:stroke .15s;}
.btab-lbl{font-size:9px;font-weight:800;color:var(--n300);letter-spacing:.6px;text-transform:uppercase;transition:color .15s;}
.btab.on .btab-ico svg{stroke:var(--o600);}
.btab.on .btab-lbl{color:var(--o600);}
.btab-gap{width:52px;flex-shrink:0;}

/* ── FAB ── */
.fab{position:fixed;bottom:74px;right:calc(50% - 214px);width:50px;height:50px;background:var(--o600);border-radius:50%;border:none;cursor:pointer;box-shadow:0 8px 22px rgba(234,101,0,.4);display:flex;align-items:center;justify-content:center;z-index:200;transition:transform .18s,background .2s;}
.fab:active{transform:scale(.91);}
.fab.open{background:var(--r600);}
.fab svg{width:18px;height:18px;stroke:#fff;stroke-width:2.5;fill:none;stroke-linecap:round;transition:transform .22s;}
.fab.open svg{transform:rotate(45deg);}

/* ── Pages ── */
.page{display:none;}
.page.on{display:block;animation:pgIn .2s ease;}
@keyframes pgIn{from{opacity:0;transform:translateY(7px);}to{opacity:1;transform:translateY(0);}}

/* ── Page header ── */
.ph{padding:22px 20px 6px;}
.ph-eyebrow{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.ph-dot{width:7px;height:7px;border-radius:50%;background:var(--o500);}
.ph-eye-txt{font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--o600);}
.ph-title{font-family:'Clash Display',sans-serif;font-size:26px;font-weight:700;color:var(--n800);line-height:1.2;margin-bottom:5px;}
.ph-sub{font-size:13px;font-weight:500;color:var(--n400);line-height:1.5;}

/* ── Cards ── */
.card{background:var(--w);border-radius:var(--rad-l);border:1.5px solid var(--n150);box-shadow:var(--sh-xs);}
.card-p{padding:18px 18px;}

/* ── Section bar ── */
.sbar{display:flex;align-items:center;justify-content:space-between;padding:18px 20px 10px;}
.sbar-title{font-size:11px;font-weight:800;letter-spacing:1.3px;text-transform:uppercase;color:var(--n400);}
.sbar-btn{display:flex;align-items:center;gap:5px;background:var(--o50);border:1.5px solid var(--o200);border-radius:99px;padding:5px 13px;cursor:pointer;border:none;font-family:'Manrope',sans-serif;background:var(--o50);}
.sbar-btn span{font-size:12px;font-weight:700;color:var(--o600);}
.sbar-btn svg{width:12px;height:12px;stroke:var(--o600);stroke-width:2.5;fill:none;stroke-linecap:round;}
.sbar-btn:active{background:var(--o100);}

/* ── Del button ── */
.del-btn{width:28px;height:28px;border-radius:var(--rad-xs);background:var(--r50);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.del-btn svg{width:11px;height:11px;stroke:var(--r500);stroke-width:2.5;fill:none;stroke-linecap:round;}
.del-btn:active{background:var(--r100);}

/* ══════════════════════════════
   PAGE 1 — INCOME TABLE
══════════════════════════════ */
/* Hero card */
.hero-card{margin:14px 16px 0;background:linear-gradient(135deg,var(--o600) 0%,var(--o700) 100%);border-radius:var(--rad-l);padding:22px 20px 20px;position:relative;overflow:hidden;}
.hero-card::before{content:'';position:absolute;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.07);top:-80px;right:-60px;pointer-events:none;}
.hero-card::after{content:'';position:absolute;width:140px;height:140px;border-radius:50%;background:rgba(255,255,255,.04);bottom:-50px;left:-20px;pointer-events:none;}
.hero-eyebrow{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:7px;}
.hero-net{font-family:'Clash Display',sans-serif;font-size:42px;font-weight:700;color:#fff;letter-spacing:-1.5px;line-height:1;margin-bottom:18px;}
.hero-net.neg{color:#FFCAB4;}
.hero-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.hero-stat{background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.14);border-radius:12px;padding:11px 12px;}
.hero-stat-lbl{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:rgba(255,255,255,.42);margin-bottom:4px;}
.hero-stat-val{font-family:'DM Mono',monospace;font-size:15px;font-weight:500;color:#fff;}
.hero-stat-val.g{color:#A7F3D0;}
.hero-stat-val.r{color:#FCA5A5;}

/* Income table */
.income-table-wrap{margin:14px 16px;overflow:hidden;}
.inc-table{width:100%;border-collapse:collapse;}
.inc-table thead th{font-size:10px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--n400);padding:0 12px 10px;text-align:left;border-bottom:2px solid var(--n150);}
.inc-table thead th:nth-child(3){text-align:right;}
.inc-table tbody tr{border-bottom:1px solid var(--n100);transition:background .12s;}
.inc-table tbody tr:last-child{border-bottom:none;}
.inc-table tbody tr:active{background:var(--n50);}
.inc-table td{padding:10px 12px;vertical-align:middle;}
.inc-type-pill{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:3px 8px;border-radius:99px;letter-spacing:.2px;white-space:nowrap;}
.inc-type-pill.add{background:var(--g100);color:var(--g600);}
.inc-type-pill.ded{background:var(--r100);color:var(--r600);}
.inc-type-pill.sub{background:var(--o100);color:var(--o700);}
.inc-row-name{font-size:13px;font-weight:600;color:var(--n700);}
.inc-row-note{font-size:11px;color:var(--n400);font-weight:500;margin-top:1px;}
.inc-row-amt{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;text-align:right;white-space:nowrap;}
.inc-row-amt.add{color:var(--g600);}
.inc-row-amt.ded{color:var(--r600);}
.inc-sub-row td{background:var(--n50);font-weight:700;font-size:13px;}
.inc-sub-row td:last-child{font-family:'DM Mono',monospace;font-size:14px;}
.inc-total-row td{background:var(--o50);border-top:2px solid var(--o200);font-size:14px;font-weight:800;color:var(--n800);}
.inc-total-row td:last-child{font-family:'DM Mono',monospace;font-size:16px;color:var(--o700);}
.inc-total-row td{padding:12px 12px;}
.inc-actions-cell{display:flex;align-items:center;justify-content:flex-end;gap:6px;}
.edit-btn{width:28px;height:28px;border-radius:var(--rad-xs);background:var(--b50);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.edit-btn svg{width:12px;height:12px;stroke:var(--b500);stroke-width:2.2;fill:none;stroke-linecap:round;stroke-linejoin:round;}
.edit-btn:active{background:var(--b100);}
.inc-empty{padding:18px;font-size:13px;color:var(--n300);font-weight:500;text-align:center;}

/* ══════════════════════════════
   PAGE 2 — TRACKER
══════════════════════════════ */
.cal-card{margin:14px 16px 0;}
.cal-inner{padding:16px 16px 14px;}
.cal-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.cal-month{font-family:'Clash Display',sans-serif;font-size:16px;font-weight:700;color:var(--n700);}
.cal-wk{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:6px;}
.cal-wk-lbl{text-align:center;font-size:10px;font-weight:700;color:var(--n300);letter-spacing:.4px;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cal-cell{aspect-ratio:1;border-radius:9px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .13s;position:relative;}
.cal-cell:not(.empty):active{transform:scale(.88);}
.cal-num{font-size:12px;font-weight:700;color:var(--n500);line-height:1;}
.cal-dot{width:3px;height:3px;border-radius:50%;margin-top:2px;}
.cal-cell.today .cal-num{background:var(--o600);color:#fff;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
.cal-cell.sel{background:var(--o50);outline:2px solid var(--o400);}
.cal-cell.sel .cal-num{color:var(--o700);}
.cal-cell.has{background:var(--n100);}
.cal-cell.empty{pointer-events:none;}

/* Day panel */
.day-panel{margin:10px 16px 0;}
.dp-head{display:flex;align-items:center;justify-content:space-between;padding:13px 16px 11px;border-bottom:1.5px solid var(--n100);}
.dp-date{font-size:14px;font-weight:800;color:var(--n700);}
.dp-total{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--r600);}
.dp-empty-msg{padding:16px;font-size:13px;font-weight:500;color:var(--n300);text-align:center;}
.dp-row{display:flex;align-items:center;gap:9px;padding:10px 14px;border-bottom:1.5px solid var(--n100);}
.dp-row:last-child{border-bottom:none;}
.dp-cat-chip{font-size:10px;font-weight:700;padding:2px 8px;border-radius:99px;flex-shrink:0;}
.dp-name{flex:1;font-size:13px;font-weight:600;color:var(--n600);}
.dp-amt{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--r600);flex-shrink:0;margin-right:4px;}

/* Quick categories */
.qcat-section{margin:14px 16px 0;}
.qcat-label{font-size:11px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--n400);margin-bottom:10px;}
.qcat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;}
.qcat-item{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;}
.qcat-ico{width:50px;height:50px;border-radius:15px;display:flex;align-items:center;justify-content:center;border:2px solid transparent;transition:all .15s;}
.qcat-ico svg{width:22px;height:22px;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round;transition:stroke .15s;}
.qcat-lbl{font-size:10px;font-weight:700;color:var(--n400);transition:color .15s;}
.qcat-item.sel .qcat-ico{outline:2.5px solid var(--o500);}
.qcat-item.sel .qcat-lbl{color:var(--o700);}
.qcat-item:active .qcat-ico{transform:scale(.88);}

/* Quick input */
.qadd-bar{display:flex;gap:8px;margin:12px 16px 16px;}
.qa-inp{background:var(--w);border:2px solid var(--n200);border-radius:var(--rad-m);padding:13px 14px;font-size:15px;font-weight:800;color:var(--n800);font-family:'Manrope',sans-serif;outline:none;transition:border-color .15s;-webkit-appearance:none;width:0;flex:1;}
.qa-inp:focus{border-color:var(--o400);}
.qa-inp::placeholder{color:var(--n300);font-weight:400;font-size:13px;}
.qa-desc{background:var(--w);border:2px solid var(--n200);border-radius:var(--rad-m);padding:13px 14px;font-size:13px;font-weight:600;color:var(--n800);font-family:'Manrope',sans-serif;outline:none;transition:border-color .15s;-webkit-appearance:none;width:0;flex:1.1;}
.qa-desc:focus{border-color:var(--o400);}
.qa-desc::placeholder{color:var(--n300);font-weight:400;}
.qa-submit{background:var(--o600);color:#fff;border:none;border-radius:var(--rad-m);padding:0 18px;font-size:13px;font-weight:800;cursor:pointer;font-family:'Manrope',sans-serif;box-shadow:0 4px 14px rgba(234,101,0,.3);transition:opacity .15s,transform .1s;flex-shrink:0;}
.qa-submit:active{opacity:.85;transform:scale(.96);}

/* ══════════════════════════════
   PAGE 3 — ANALYSIS
══════════════════════════════ */
/* Top 2 chips */
.an-top{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:14px 16px 0;}
.an-chip{border-radius:var(--rad-m);padding:18px 16px;border:1.5px solid transparent;}
.an-chip.income{background:var(--g50);border-color:var(--g100);}
.an-chip.outcome{background:var(--r50);border-color:var(--r100);}
.an-chip-ico{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;}
.an-chip.income .an-chip-ico{background:var(--g100);}
.an-chip.income .an-chip-ico svg{stroke:var(--g600);}
.an-chip.outcome .an-chip-ico{background:var(--r100);}
.an-chip.outcome .an-chip-ico svg{stroke:var(--r600);}
.an-chip-ico svg{width:18px;height:18px;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round;}
.an-chip-lbl{font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.an-chip.income .an-chip-lbl{color:var(--g600);}
.an-chip.outcome .an-chip-lbl{color:var(--r600);}
.an-chip-val{font-family:'DM Mono',monospace;font-size:20px;font-weight:500;color:var(--n800);letter-spacing:-.5px;}
.an-chip-sub{font-size:11px;font-weight:600;color:var(--n400);margin-top:4px;}

/* Donut */
.donut-card{margin:12px 16px 0;}
.donut-layout{display:flex;align-items:center;gap:16px;}
.donut-svg-wrap{position:relative;width:130px;height:130px;flex-shrink:0;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-center-val{font-family:'DM Mono',monospace;font-size:17px;font-weight:500;color:var(--n800);}
.donut-center-lbl{font-size:9px;font-weight:700;color:var(--n400);letter-spacing:1px;text-transform:uppercase;margin-top:2px;}
.leg-list{flex:1;display:flex;flex-direction:column;gap:9px;}
.leg-row{display:flex;align-items:center;gap:8px;}
.leg-dot{width:9px;height:9px;border-radius:2px;flex-shrink:0;}
.leg-name{flex:1;font-size:12px;font-weight:600;color:var(--n500);}
.leg-pct{font-size:13px;font-weight:800;color:var(--n700);}

/* Top spender highlight */
.top-spender{margin:12px 16px 0;background:linear-gradient(135deg,var(--o600),var(--o700));border-radius:var(--rad-m);padding:16px 18px;display:flex;align-items:center;gap:14px;}
.ts-left{flex:1;}
.ts-eye{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:5px;}
.ts-name{font-family:'Clash Display',sans-serif;font-size:20px;font-weight:700;color:#fff;margin-bottom:4px;}
.ts-pct{font-size:13px;font-weight:600;color:rgba(255,255,255,.7);}
.ts-right{text-align:right;}
.ts-amt{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;color:#fff;}
.ts-sub{font-size:11px;color:rgba(255,255,255,.55);margin-top:3px;}

/* Bar chart */
.bar-card{margin:12px 16px 0;}
.bar-rows{display:flex;flex-direction:column;gap:11px;}
.bar-row{display:flex;align-items:center;gap:11px;}
.bar-lbl{width:44px;font-size:11px;font-weight:700;color:var(--n400);flex-shrink:0;text-align:right;line-height:1.3;}
.bar-track{flex:1;height:8px;background:var(--n100);border-radius:99px;overflow:hidden;}
.bar-fill{height:100%;border-radius:99px;transition:width .7s cubic-bezier(.4,0,.2,1);}
.bar-val{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;color:var(--n500);width:60px;text-align:right;flex-shrink:0;}

/* AI Analysis */
.ai-card{margin:12px 16px 0;}
.ai-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.ai-badge{display:inline-flex;align-items:center;gap:6px;background:var(--o100);border:1.5px solid var(--o200);border-radius:99px;padding:5px 12px;}
.ai-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--o500);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
.ai-badge-txt{font-size:11px;font-weight:800;color:var(--o700);letter-spacing:.5px;}
.ai-loading{text-align:center;padding:20px;color:var(--n300);font-size:13px;font-weight:500;}
.ai-insight{padding:14px;border-radius:var(--rad-m);margin-bottom:9px;border:1.5px solid transparent;}
.ai-insight:last-child{margin-bottom:0;}
.ai-insight.alert{background:var(--r50);border-color:var(--r100);}
.ai-insight.warn{background:var(--o50);border-color:var(--o100);}
.ai-insight.good{background:var(--g50);border-color:var(--g100);}
.ai-insight.info{background:var(--b50);border-color:var(--b100);}
.ai-i-head{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:5px;}
.ai-i-title{font-size:13px;font-weight:800;line-height:1.3;}
.ai-insight.alert .ai-i-title{color:var(--r600);}
.ai-insight.warn .ai-i-title{color:var(--o700);}
.ai-insight.good .ai-i-title{color:var(--g600);}
.ai-insight.info .ai-i-title{color:var(--b600);}
.ai-i-badge{font-size:10px;font-weight:800;padding:3px 8px;border-radius:99px;flex-shrink:0;white-space:nowrap;}
.ai-insight.alert .ai-i-badge{background:var(--r500);color:#fff;}
.ai-insight.warn .ai-i-badge{background:var(--o500);color:#fff;}
.ai-insight.good .ai-i-badge{background:var(--g500);color:#fff;}
.ai-insight.info .ai-i-badge{background:var(--b500);color:#fff;}
.ai-i-body{font-size:12px;font-weight:500;color:var(--n500);line-height:1.55;}

/* ══════════════════════════════
   PAGE 4 — SETTINGS
══════════════════════════════ */
.settings-section{margin:0 16px 14px;}
.settings-group{background:var(--w);border-radius:var(--rad-l);border:1.5px solid var(--n150);overflow:hidden;}
.sg-row{display:flex;align-items:center;padding:14px 16px;border-bottom:1.5px solid var(--n100);}
.sg-row:last-child{border-bottom:none;}
.sg-ico{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-right:12px;}
.sg-ico svg{width:18px;height:18px;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round;}
.sg-body{flex:1;}
.sg-name{font-size:14px;font-weight:700;color:var(--n700);}
.sg-sub{font-size:11px;font-weight:500;color:var(--n400);margin-top:2px;}
.sg-right{margin-left:10px;}
.sg-val{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--o600);}
.sg-input{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--n700);border:2px solid var(--n200);border-radius:var(--rad-xs);padding:7px 10px;width:110px;text-align:right;background:var(--n50);outline:none;-webkit-appearance:none;}
.sg-input:focus{border-color:var(--o400);background:var(--w);}
.sg-toggle{width:44px;height:24px;border-radius:99px;border:none;cursor:pointer;transition:background .2s;position:relative;flex-shrink:0;}
.sg-toggle.on{background:var(--o500);}
.sg-toggle.off{background:var(--n200);}
.sg-toggle::after{content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);}
.sg-toggle.on::after{left:23px;}
.sg-toggle.off::after{left:3px;}

/* Goal progress */
.goal-progress{margin:14px 16px 0;background:var(--w);border-radius:var(--rad-l);border:1.5px solid var(--n150);padding:18px;}
.gp-title{font-size:13px;font-weight:800;color:var(--n700);margin-bottom:14px;}
.gp-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.gp-lbl{font-size:13px;font-weight:600;color:var(--n600);}
.gp-val{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--n700);}
.gp-track{height:10px;background:var(--n100);border-radius:99px;overflow:hidden;margin-bottom:6px;}
.gp-fill{height:100%;border-radius:99px;transition:width .6s cubic-bezier(.4,0,.2,1);}
.gp-status{font-size:12px;font-weight:600;text-align:right;}

/* Fixed expenses */
.fix-item{display:flex;align-items:center;gap:11px;padding:12px 14px;border-bottom:1.5px solid var(--n100);}
.fix-item:last-child{border-bottom:none;}
.fix-ico{width:36px;height:36px;border-radius:10px;background:var(--o50);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.fix-ico svg{width:17px;height:17px;stroke:var(--o600);stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round;}
.fix-body{flex:1;min-width:0;}
.fix-name{font-size:14px;font-weight:700;color:var(--n700);}
.fix-note{font-size:11px;color:var(--n400);margin-top:1px;}
.fix-amt{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--r600);flex-shrink:0;}

/* ═══ SHEET ═══ */
.overlay{position:fixed;inset:0;background:rgba(28,20,16,.28);backdrop-filter:blur(4px);z-index:150;opacity:0;pointer-events:none;transition:opacity .22s;}
.overlay.on{opacity:1;pointer-events:all;}
.sheet{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:430px;background:var(--w);border-radius:24px 24px 0 0;z-index:200;padding:0 20px 36px;transition:transform .28s cubic-bezier(.32,.72,0,1);max-height:90vh;overflow-y:auto;}
.sheet.on{transform:translateX(-50%) translateY(0);}
.sh-handle{width:40px;height:4px;background:var(--n200);border-radius:99px;margin:13px auto 18px;}
.sh-title{font-family:'Clash Display',sans-serif;font-size:22px;font-weight:700;color:var(--n800);margin-bottom:18px;}

/* Form */
.fld{margin-bottom:13px;}
.fl{display:block;font-size:10px;font-weight:800;letter-spacing:1.3px;text-transform:uppercase;color:var(--n400);margin-bottom:6px;}
.fi{width:100%;padding:13px 14px;border:2px solid var(--n200);border-radius:var(--rad-s);font-size:14px;font-weight:600;color:var(--n800);font-family:'Manrope',sans-serif;background:var(--w);outline:none;transition:border-color .15s;-webkit-appearance:none;}
.fi:focus{border-color:var(--o500);}
.fi::placeholder{color:var(--n300);font-weight:400;}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.type-toggle{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:14px;}
.tt-btn{padding:11px 6px;border-radius:var(--rad-m);border:2px solid var(--n200);font-size:12px;font-weight:700;cursor:pointer;font-family:'Manrope',sans-serif;background:var(--w);color:var(--n400);transition:all .15s;text-align:center;}
.tt-btn.on-add{background:var(--g50);border-color:var(--g500);color:var(--g600);}
.tt-btn.on-ded{background:var(--r50);border-color:var(--r500);color:var(--r600);}
.tt-btn.on-sub{background:var(--o50);border-color:var(--o500);color:var(--o700);}
.presets{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:13px;}
.pchip{padding:7px 13px;background:var(--n100);border:1.5px solid var(--n200);border-radius:99px;font-size:12px;font-weight:700;color:var(--n600);cursor:pointer;font-family:'DM Mono',monospace;transition:all .15s;}
.pchip:active{background:var(--o50);border-color:var(--o300);color:var(--o700);}
.btn-p{width:100%;padding:15px;background:var(--o600);color:#fff;border:none;border-radius:var(--rad-m);font-size:15px;font-weight:800;cursor:pointer;font-family:'Manrope',sans-serif;box-shadow:0 6px 18px rgba(234,101,0,.28);transition:opacity .15s,transform .1s;}
.btn-p:active{opacity:.88;transform:scale(.99);}
.btn-s{width:100%;padding:13px;background:var(--n100);border:none;border-radius:var(--rad-m);font-size:14px;font-weight:700;color:var(--n500);cursor:pointer;font-family:'Manrope',sans-serif;margin-top:8px;}
.btn-s:active{background:var(--n150);}

/* Toast */
.toast{position:fixed;bottom:94px;left:50%;transform:translateX(-50%);background:var(--n700);color:#fff;padding:10px 20px;border-radius:99px;font-size:13px;font-weight:700;z-index:999;opacity:0;pointer-events:none;transition:opacity .22s;white-space:nowrap;}
.toast.on{opacity:1;}

.empty-state{padding:18px;font-size:13px;font-weight:500;color:var(--n300);text-align:center;border-radius:var(--rad-m);background:var(--w);border:1.5px dashed var(--n200);}
input[type=number]{-moz-appearance:textfield;}
input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;}
</style>
</head>
