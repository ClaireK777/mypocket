    svg:`<rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>` },
  { id:'loan',   lbl:'貸款',   color:'#DC2626', bg:'#FFF1F2',
    svg:`<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><path d="M7 15h2M11 15h4"/>` },
  { id:'sub',    lbl:'訂閱',   color:'#0891B2', bg:'#ECFEFF',
    svg:`<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>` },
  { id:'health', lbl:'醫療',   color:'#16A34A', bg:'#F0FDF4',
    svg:`<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>` },
  { id:'social', lbl:'交際',   color:'#D97706', bg:'#FFFBEB',
    svg:`<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/>` },
  { id:'other',  lbl:'其他',   color:'#6B7280', bg:'#F9FAFB',
    svg:`<circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>` },
];

const MNAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const MSHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DNAMES = ['日','一','二','三','四','五','六'];

/* ═══════════════════════════════════
   STATE
═══════════════════════════════════ */
let cy, cm, selDate = null;
let selCat = 'food';
let incType = 'add';
let editingIncIdx = null;

// Persistent data
let incItems = [];    // [{type:'add'|'ded'|'sub', name, amt, note}]
let fixItems = [];    // [{name, amt, note}]
let expData  = {};    // {YYYY-MM: [{cat, amt, desc, date}]}

// Settings
let settings = { goal: 0, dailyLimit: 0, emergency: 0 };

function ekey(y, m) { return `${y}-${String(m).padStart(2,'0')}`; }
function curExps() {
  const k = ekey(cy, cm);
  if (!expData[k]) expData[k] = [];
  return expData[k];
}

function saveAll() {
  localStorage.setItem('mypocket2', JSON.stringify({ incItems, fixItems, expData, settings }));
}
function loadAll() {
  const r = localStorage.getItem('mypocket2');
  if (r) {
    const p = JSON.parse(r);
    incItems = p.incItems || [];
    fixItems = p.fixItems || [];
    expData  = p.expData  || {};
    settings = p.settings || { goal:0, dailyLimit:0, emergency:0 };
  }
}

/* ═══════════════════════════════════
   INIT
═══════════════════════════════════ */
(function init() {
  loadAll();
  const n = new Date();
  cy = n.getFullYear(); cm = n.getMonth() + 1;
  const todayStr = `${cy}-${String(cm).padStart(2,'0')}-${String(n.getDate()).padStart(2,'0')}`;
  selDate = todayStr;
  buildQcatGrid();
  loadSettingsInputs();
  render();
})();

function chm(d) {
  cm += d;
  if (cm > 12) { cm = 1; cy++; }
  if (cm < 1)  { cm = 12; cy--; }
  selDate = null;
  render();
}

/* ═══════════════════════════════════
   CALC HELPERS
═══════════════════════════════════ */
function calcIncome() {
  const adds = incItems.filter(x => x.type === 'add').reduce((s,x) => s + x.amt, 0);
  const deds = incItems.filter(x => x.type === 'ded').reduce((s,x) => s + x.amt, 0);
  return { adds, deds, net: adds - deds };
}
function calcFix()  { return fixItems.reduce((s,x) => s + x.amt, 0); }
function calcExp()  { return curExps().reduce((s,x) => s + x.amt, 0); }

/* ═══════════════════════════════════
   RENDER
═══════════════════════════════════ */
function render() {
  document.getElementById('mlbl').textContent = `${MSHORT[cm-1]} ${cy}`;
  const { adds, deds, net } = calcIncome();
  const fix = calcFix();
  const exp = calcExp();
  const bal = net - fix - exp;
  renderIncome(adds, deds, net);
  renderTracker();
  renderAnalysis(net, fix, exp, bal);
  renderSettings(net, fix, exp, bal);
}

/* ── Income table ── */
function renderIncome(adds, deds, net) {
  const el = document.getElementById('heroNet');
  el.textContent = fmt(net);
  el.className = 'hero-net' + (net < 0 ? ' neg' : '');
  document.getElementById('heroAdds').textContent = fmt(adds);
  document.getElementById('heroDeds').textContent = fmt(deds);

  const tbody = document.getElementById('incTableBody');
  if (incItems.length === 0) {
    tbody.innerHTML = `<tr><td colspan="3" class="inc-empty">尚未新增薪資項目，點右上角「新增項目」開始</td></tr>`;
    return;
  }

  let html = '';
  incItems.forEach((x, i) => {
    const typeCls = x.type === 'add' ? 'add' : x.type === 'ded' ? 'ded' : 'sub';
    const typeLabel = x.type === 'add' ? '加項' : x.type === 'ded' ? '扣項' : '小計';
    const sign = x.type === 'add' ? '+' : x.type === 'ded' ? '−' : '=';
    const rowCls = x.type === 'sub' ? 'inc-sub-row' : '';
    html += `<tr class="${rowCls}">
      <td><span class="inc-type-pill ${typeCls}">${typeLabel}</span></td>
      <td>
        <div class="inc-row-name">${esc(x.name)}</div>
        ${x.note ? `<div class="inc-row-note">${esc(x.note)}</div>` : ''}
      </td>
      <td>
        <div class="inc-actions-cell">
          <span class="inc-row-amt ${x.type === 'sub' ? '' : typeCls}">${sign}${fmtP(x.amt)}</span>
          <button class="edit-btn" onclick="editIncItem(${i})">
            <svg viewBox="0 0 12 12"><path d="M8.5 1.5l2 2-7 7H1.5v-2l7-7z"/></svg>
          </button>
          <button class="del-btn" onclick="delIncItem(${i})">
            <svg viewBox="0 0 11 11"><line x1="1" y1="1" x2="10" y2="10"/><line x1="10" y1="1" x2="1" y2="10"/></svg>
          </button>
        </div>
      </td>
    </tr>`;
  });

  // Totals
  html += `<tr class="inc-sub-row">
    <td><span class="inc-type-pill add">合計</span></td>
    <td class="inc-row-name">應領薪資</td>
    <td class="inc-row-amt add">+${fmtP(adds)}</td>
  </tr>
  <tr class="inc-sub-row">
    <td><span class="inc-type-pill ded">合計</span></td>
    <td class="inc-row-name">總扣除額</td>
    <td class="inc-row-amt ded">−${fmtP(deds)}</td>
  </tr>
  <tr class="inc-total-row">
    <td><span class="inc-type-pill sub">實領</span></td>
    <td><strong>實領薪資</strong></td>
    <td>${fmt(net)}</td>
  </tr>`;

  tbody.innerHTML = html;
}

/* ── Calendar / Tracker ── */
function renderTracker() {
  const exps = curExps();
  document.getElementById('calTitle').textContent = `${MNAMES[cm-1]} ${cy}`;
  document.getElementById('calWk').innerHTML = DNAMES.map(d => `<div class="cal-wk-lbl">${d}</div>`).join('');

  const dayTot = {};
  exps.forEach(e => { dayTot[e.date] = (dayTot[e.date] || 0) + e.amt; });

  const first = new Date(cy, cm-1, 1).getDay();
  const days  = new Date(cy, cm, 0).getDate();
  const now   = new Date();

  let cells = '';
  for (let i = 0; i < first; i++) cells += `<div class="cal-cell empty"></div>`;
  for (let d = 1; d <= days; d++) {
    const ds = `${cy}-${String(cm).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = now.getFullYear()===cy && now.getMonth()+1===cm && now.getDate()===d;
    const hasDat  = !!dayTot[ds];
    const isSel   = selDate === ds;
    const amt     = dayTot[ds] || 0;
    const dotCol  = amt > 3000 ? 'var(--r500)' : amt > 1000 ? 'var(--o500)' : 'var(--g500)';
    cells += `<div class="cal-cell${isToday?' today':''}${hasDat?' has':''}${isSel?' sel':''}" onclick="pickDate('${ds}')">
      <div class="cal-num">${d}</div>
      ${hasDat ? `<div class="cal-dot" style="background:${dotCol}"></div>` : ''}
    </div>`;
  }
  document.getElementById('calGrid').innerHTML = cells;
  renderDayPanel(exps);
}

function pickDate(ds) { selDate = ds; renderTracker(); }

function renderDayPanel(exps) {
  const el = document.getElementById('dayPanel');
  if (!selDate) { el.innerHTML = `<div class="dp-empty-msg">點選日期查看或新增支出</div>`; return; }

  const its  = exps.map((e,i) => ({...e, _idx: i})).filter(e => e.date === selDate);
  const d    = new Date(selDate + 'T00:00:00');
  const lbl  = `${parseInt(selDate.split('-')[1])} 月 ${parseInt(selDate.split('-')[2])} 日（${DNAMES[d.getDay()]}）`;
  const tot  = its.reduce((s,e) => s + e.amt, 0);
  const dlim = settings.dailyLimit;
  const over = dlim > 0 && tot > dlim;

  let html = `<div class="dp-head">
    <div class="dp-date">${lbl}</div>
    <div>${tot > 0
      ? `<span class="dp-total" style="${over?'color:var(--r600)':''}">${over?'⚠ ':''}-${fmtP(tot)}</span>`
      : `<span style="font-size:12px;color:var(--n300);font-weight:600;">無支出</span>`}
    </div>
  </div>`;

  if (its.length === 0) {
    html += `<div class="dp-empty-msg">這天沒有支出記錄</div>`;
  } else {
    its.forEach(e => {
      const c = CATS.find(x => x.id === e.cat) || CATS[8];
      html += `<div class="dp-row">
        <span class="dp-cat-chip" style="color:${c.color};background:${c.bg}">${c.lbl}</span>
        <span class="dp-name">${esc(e.desc || c.lbl)}</span>
        <span class="dp-amt">-${fmtP(e.amt)}</span>
        <button class="del-btn" onclick="delExp(${e._idx})">
          <svg viewBox="0 0 11 11"><line x1="1" y1="1" x2="10" y2="10"/><line x1="10" y1="1" x2="1" y2="10"/></svg>
        </button>
      </div>`;
    });
  }
  el.innerHTML = html;
}

function buildQcatGrid() {
  document.getElementById('qcatGrid').innerHTML = CATS.map(c => `
    <div class="qcat-item${c.id===selCat?' sel':''}" id="qc-${c.id}" onclick="pickCat('${c.id}')">
      <div class="qcat-ico" style="background:${c.bg};">
        <svg viewBox="0 0 24 24" style="stroke:${c.color};">${c.svg}</svg>
      </div>
      <div class="qcat-lbl">${c.lbl}</div>
    </div>`).join('');
}

function pickCat(id) {
  selCat = id;
  document.querySelectorAll('.qcat-item').forEach(el => el.classList.remove('sel'));
  document.getElementById('qc-' + id).classList.add('sel');
}

function qaSubmit() {
  const amt  = parseFloat(document.getElementById('qaAmt').value);
  const desc = document.getElementById('qaDesc').value.trim();
  if (!amt || amt <= 0) { toast('請輸入金額'); return; }
  const date = selDate || `${cy}-${String(cm).padStart(2,'0')}-${String(new Date().getDate()).padStart(2,'0')}`;
  curExps().push({ amt, desc, cat: selCat, date });
  document.getElementById('qaAmt').value  = '';
  document.getElementById('qaDesc').value = '';
  saveAll(); render(); toast('記帳完成');
}

/* ── Analysis ── */
function renderAnalysis(net, fix, exp, bal) {
  const totalOut = fix + exp;
  document.getElementById('anInc').textContent = fmt(net);
  document.getElementById('anIncSub').textContent = `實領薪資`;
  document.getElementById('anOut').textContent = fmt(totalOut);
  document.getElementById('anOutSub').textContent = `固定 ${fmt(fix)} ＋ 每日 ${fmtShort(exp)}`;

  // Category totals
  const catT = {};
  CATS.forEach(c => catT[c.id] = 0);
  curExps().forEach(e => { catT[e.cat] = (catT[e.cat]||0) + e.amt; });

  // Include fixed as a pseudo-category for analysis
  const allOut = [];
  CATS.filter(c => catT[c.id] > 0).forEach(c => allOut.push({ lbl: c.lbl, amt: catT[c.id], color: c.color }));
  if (fix > 0) allOut.push({ lbl: '固定支出', amt: fix, color: '#6B7280' });
  allOut.sort((a,b) => b.amt - a.amt);

  const totalForDonut = allOut.reduce((s,x) => s + x.amt, 0);
  document.getElementById('donutVal').textContent = fmtShort(totalForDonut);

  // Top spender
  const ts = document.getElementById('topSpender');
  if (allOut.length > 0) {
    const top = allOut[0];
    ts.style.display = 'flex';
    document.getElementById('tsName').textContent = top.lbl;
    document.getElementById('tsPct').textContent  = `佔總支出 ${totalForDonut>0?(top.amt/totalForDonut*100).toFixed(0):0}%`;
    document.getElementById('tsAmt').textContent  = fmt(top.amt);
  } else {
    ts.style.display = 'none';
  }

  // Donut
  renderDonut(allOut, totalForDonut);

  // Bar chart
  const maxV = Math.max(...allOut.map(x => x.amt), 1);
  document.getElementById('barRows').innerHTML = allOut.length === 0
    ? `<div style="font-size:13px;color:var(--n300);text-align:center;padding:8px;">本月尚無支出記錄</div>`
    : allOut.map(x => `<div class="bar-row">
        <div class="bar-lbl">${x.lbl}</div>
        <div class="bar-track"><div class="bar-fill" style="width:${(x.amt/maxV*100).toFixed(1)}%;background:${x.color}"></div></div>
        <div class="bar-val">${fmt(x.amt)}</div>
      </div>`).join('');

  // AI analysis
  renderAI(net, fix, exp, bal, allOut, totalForDonut);
}

function renderDonut(items, total) {
  const svg = document.getElementById('donutSvg');
  const cx = 65, cy2 = 65, r = 50, sw = 16;
  const circ = 2 * Math.PI * r;
  if (total === 0 || items.length === 0) {
    svg.innerHTML = `<circle cx="${cx}" cy="${cy2}" r="${r}" fill="none" stroke="#E2DDD5" stroke-width="${sw}"/>`;
    document.getElementById('legList').innerHTML = `<div style="font-size:12px;color:var(--n300);font-weight:500;">尚無支出資料</div>`;
    return;
  }
  let off = 0;
  const segs = items.map(x => {
    const pct  = x.amt / total;
    const dash = pct * circ;
    const gap  = circ - dash;
    const seg  = `<circle cx="${cx}" cy="${cy2}" r="${r}" fill="none" stroke="${x.color}" stroke-width="${sw}"
      stroke-dasharray="${dash.toFixed(2)} ${gap.toFixed(2)}"
      stroke-dashoffset="${(-off * circ + circ / 4).toFixed(2)}"
      stroke-linecap="butt"/>`;
    off += pct;
    return seg;
  }).join('');
  svg.innerHTML = `<circle cx="${cx}" cy="${cy2}" r="${r}" fill="none" stroke="#F5F3EF" stroke-width="${sw}"/>` + segs;

  document.getElementById('legList').innerHTML = items.slice(0, 5).map(x => `
    <div class="leg-row">
      <div class="leg-dot" style="background:${x.color}"></div>
      <div class="leg-name">${x.lbl}</div>
      <div class="leg-pct">${(x.amt/total*100).toFixed(0)}%</div>
    </div>`).join('');
}

/* ── AI Analysis (rule-based intelligent insights) ── */
function renderAI(net, fix, exp, bal, allOut, totalOut) {
  const aiEl = document.getElementById('aiContent');
  const insights = [];

  const fixPct = net > 0 ? fix / net * 100 : 0;
  const expPct = net > 0 ? exp / net * 100 : 0;
  const savePct = net > 0 ? bal / net * 100 : 0;
  const goal = settings.goal;
  const dlim = settings.dailyLimit;

  if (net === 0) {
    insights.push({ type:'info', title:'尚未設定薪資', body:'請前往薪資頁設定本月收入與扣除項目，才能產生完整分析。', badge:'提示' });
  } else {
    // Balance alert
    if (bal < 0) {
      insights.push({ type:'alert', title:`本月透支 ${fmtP(Math.abs(bal))}`, body:`收入 ${fmt(net)} 無法覆蓋支出 ${fmt(totalOut)}。建議立即削減非必要消費，優先保留緊急備用金。`, badge:'緊急' });
    }

    // Goal tracking
    if (goal > 0) {
      if (bal >= goal) {
        insights.push({ type:'good', title:`儲蓄目標達成！存下 ${fmt(bal)}`, body:`本月結餘 ${fmt(bal)} 超過目標 ${fmt(goal)}，超額完成 ${fmt(bal-goal)}。繼續保持這個優秀習慣。`, badge:'達標' });
      } else if (bal > 0) {
        const gap = goal - bal;
        insights.push({ type:'warn', title:`距儲蓄目標還差 ${fmt(gap)}`, body:`本月目標 ${fmt(goal)}，目前結餘 ${fmt(bal)}（${(bal/goal*100).toFixed(0)}%）。可試著減少 ${allOut[0]?.lbl || '高消費項目'} 的支出。`, badge:'未達標' });
      } else {
        insights.push({ type:'alert', title:'本月無法達成儲蓄目標', body:`收支已呈負數，儲蓄目標 ${fmt(goal)} 本月恐無法達成。建議檢視固定支出是否有削減空間。`, badge:'未達標' });
      }
    }

    // Savings rate
    if (savePct >= 30) {
      insights.push({ type:'good', title:`儲蓄率 ${savePct.toFixed(0)}%，財務健康`, body:`一般理財建議儲蓄率達 20% 即為良好，您已超越目標。可考慮將超額儲蓄投入指數基金或定期存款，讓錢繼續工作。`, badge:'優良' });
    } else if (savePct >= 10 && savePct < 20) {
      insights.push({ type:'warn', title:`儲蓄率 ${savePct.toFixed(0)}%，尚可改善`, body:`距理想的 20% 儲蓄率還有空間。若能壓縮 ${allOut[0]?.lbl || '最高消費類別'} 的花費，每月可多存約 ${fmt(net * 0.05)} 元。`, badge:'待改善' });
    }

    // Fixed cost ratio
    if (fixPct > 60) {
      insights.push({ type:'alert', title:`固定支出佔薪資 ${fixPct.toFixed(0)}%，過高`, body:`固定支出已超過薪資的 60%，屬高風險財務結構。建議審視是否有可取消的訂閱或協商降低貸款利率，目標壓至 50% 以下。`, badge:'警告' });
    } else if (fixPct > 45) {
      insights.push({ type:'warn', title:`固定支出佔薪資 ${fixPct.toFixed(0)}%`, body:`偏高的固定支出會壓縮靈活資金。建議下個月起逐步檢視各固定項目，目標在 45% 以內以保有彈性。`, badge:'注意' });
    }

    // Top spending category
    if (allOut.length > 0) {
      const top = allOut[0];
      const topPct = totalOut > 0 ? top.amt / net * 100 : 0;
      if (topPct >= 25) {
        insights.push({ type:'alert', title:`${top.lbl} 是最大支出破口（${topPct.toFixed(0)}%）`, body:`${top.lbl} 本月花費 ${fmt(top.amt)}，佔薪資的 ${topPct.toFixed(0)}%。建議設立這個類別的月度預算，超支時即時提醒自己。`, badge:'破口' });
      } else if (topPct >= 15) {
        insights.push({ type:'warn', title:`${top.lbl} 支出偏高（${topPct.toFixed(0)}%）`, body:`${top.lbl} 是本月最大消費類別。可試著設定每週限額，逐步降低比例，目標控制在薪資 10-15% 內。`, badge:'偏高' });
      }
    }

    // Daily limit check
    if (dlim > 0) {
      const today = new Date().toISOString().split('T')[0];
      const todayAmt = curExps().filter(e => e.date === today).reduce((s,e) => s + e.amt, 0);
      if (todayAmt > dlim) {
        insights.push({ type:'alert', title:`今日已超出每日上限 ${fmt(dlim)}`, body:`今日支出 ${fmt(todayAmt)}，超出預設上限 ${fmt(todayAmt-dlim)}。請留意今日剩餘消費。`, badge:'超限' });
      }
    }

    // Emergency fund check
    if (settings.emergency > 0) {
      const months = settings.emergency / (net || 1);
      if (months < 3) {
        insights.push({ type:'warn', title:'緊急備用金目標偏低', body:`設定的緊急備用金 ${fmt(settings.emergency)} 約為 ${months.toFixed(1)} 個月薪資，建議提高至 3–6 個月（${fmt(net*3)}–${fmt(net*6)}）以應對突發狀況。`, badge:'建議' });
      }
    }

    // Diversification tip
    if (allOut.length >= 2 && allOut[0].amt > totalOut * 0.5) {
      insights.push({ type:'info', title:'支出過度集中於單一類別', body:`${allOut[0].lbl} 佔了總支出的 ${(allOut[0].amt/totalOut*100).toFixed(0)}%，財務彈性不足。均衡分配消費有助於更清楚掌握各生活面向的花費。`, badge:'建議' });
    }
  }

  if (insights.length === 0) {
    insights.push({ type:'good', title:'本月財務表現優秀', body:'支出結構均衡，儲蓄達標，無明顯財務風險。建議持續記錄每月數據，累積更多資料可做出更精準的趨勢分析。', badge:'良好' });
  }

  aiEl.innerHTML = insights.map(x => `
    <div class="ai-insight ${x.type}">
      <div class="ai-i-head">
        <div class="ai-i-title">${x.title}</div>
        <div class="ai-i-badge">${x.badge}</div>
      </div>
      <div class="ai-i-body">${x.body}</div>
    </div>`).join('');
}

/* ── Settings ── */
function renderSettings(net, fix, exp, bal) {
  // Goal progress
  const goal = settings.goal;
  document.getElementById('gpGoal').textContent = goal > 0 ? fmt(goal) : '未設定';
  document.getElementById('gpBal').textContent  = fmt(bal);

  const pct = goal > 0 ? Math.min(Math.max(bal / goal * 100, 0), 100) : 0;
  const fill = document.getElementById('gpFill');
  fill.style.width = pct + '%';
  fill.style.background = pct >= 100 ? 'var(--g500)' : pct >= 60 ? 'var(--o500)' : 'var(--r500)';

  const statusEl = document.getElementById('gpStatus');
  if (goal <= 0) { statusEl.textContent = '請先設定儲蓄目標'; statusEl.style.color = 'var(--n400)'; }
  else if (bal >= goal) { statusEl.textContent = `🎉 達標！超額 ${fmt(bal-goal)}`; statusEl.style.color = 'var(--g600)'; }
  else if (bal > 0) { statusEl.textContent = `距目標還差 ${fmt(goal-bal)}（${pct.toFixed(0)}%）`; statusEl.style.color = 'var(--o700)'; }
  else { statusEl.textContent = `本月透支，無法達標`; statusEl.style.color = 'var(--r600)'; }

  // Fixed items
  const fixEl = document.getElementById('fixList');
  fixEl.innerHTML = fixItems.length === 0
    ? `<div style="padding:16px;font-size:13px;color:var(--n300);text-align:center;">尚未新增固定支出</div>`
    : fixItems.map((x,i) => `<div class="fix-item">
        <div class="fix-ico"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
        <div class="fix-body">
          <div class="fix-name">${esc(x.name)}</div>
          ${x.note ? `<div class="fix-note">${esc(x.note)}</div>` : ''}
        </div>
        <div class="fix-amt">-${fmtP(x.amt)}</div>
        <button class="del-btn" onclick="delFixItem(${i})">
          <svg viewBox="0 0 11 11"><line x1="1" y1="1" x2="10" y2="10"/><line x1="10" y1="1" x2="1" y2="10"/></svg>
        </button>
      </div>`).join('');
}

function loadSettingsInputs() {
  if (settings.goal > 0) document.getElementById('goalInput').value = settings.goal;
  if (settings.dailyLimit > 0) document.getElementById('dailyLimitInput').value = settings.dailyLimit;
  if (settings.emergency > 0) document.getElementById('emergencyInput').value = settings.emergency;
}
function saveGoal() { settings.goal = parseFloat(document.getElementById('goalInput').value)||0; saveAll(); render(); }
function saveDailyLimit() { settings.dailyLimit = parseFloat(document.getElementById('dailyLimitInput').value)||0; saveAll(); }
function saveEmergency() { settings.emergency = parseFloat(document.getElementById('emergencyInput').value)||0; saveAll(); render(); }

/* ═══════════════════════════════════
   CRUD
═══════════════════════════════════ */
function setIncType(t) {
  incType = t;
  ['add','ded','sub'].forEach(x => {
    const btn = document.getElementById('tt-'+x);
    btn.className = 'tt-btn' + (t===x ? ` on-${x}` : '');
  });
  const presets = t==='add' ? [25000,30000,35000,40000,50000] : t==='ded' ? [600,1050,1200,2000,5000] : [10000,15000,20000];
  document.getElementById('incPresets').innerHTML = presets.map(v =>
    `<div class="pchip" onclick="document.getElementById('incAmt').value=${v}">${fmt(v)}</div>`).join('');
}

function openSheet(type) {
  closeSheet();
  if (type === 'income-add') {
    editingIncIdx = null;
    document.getElementById('shIncTitle').textContent = '新增薪資項目';
    document.getElementById('incName').value = '';
    document.getElementById('incAmt').value  = '';
    document.getElementById('incNote').value = '';
    setIncType('add');
    document.getElementById('sh-income').classList.add('on');
  } else if (type === 'fix-add') {
    document.getElementById('fixName').value = '';
    document.getElementById('fixAmt').value  = '';
    document.getElementById('fixNote').value = '';
    document.getElementById('sh-fix').classList.add('on');
  }
  document.getElementById('overlay').classList.add('on');
  document.getElementById('fab').classList.add('open');
}

function editIncItem(i) {
  const x = incItems[i];
  editingIncIdx = i;
  document.getElementById('shIncTitle').textContent = '編輯薪資項目';
  document.getElementById('incName').value = x.name;
  document.getElementById('incAmt').value  = x.amt;
  document.getElementById('incNote').value = x.note || '';
  setIncType(x.type);
  document.getElementById('sh-income').classList.add('on');
  document.getElementById('overlay').classList.add('on');
  document.getElementById('fab').classList.add('open');
}

function saveIncItem() {
  const name = document.getElementById('incName').value.trim();
  const amt  = parseFloat(document.getElementById('incAmt').value);
  const note = document.getElementById('incNote').value.trim();
  if (!name || isNaN(amt) || amt <= 0) { toast('請填寫名稱與金額'); return; }
  const item = { type: incType, name, amt, note };
  if (editingIncIdx !== null) {
    incItems[editingIncIdx] = item;
    toast('項目已更新');
  } else {
    incItems.push(item);
    toast(incType==='add'?'加項已儲存':incType==='ded'?'扣項已儲存':'小計已儲存');
  }
  saveAll(); render(); closeSheet();
}

function saveFixItem() {
  const name = document.getElementById('fixName').value.trim();
  const amt  = parseFloat(document.getElementById('fixAmt').value);
  const note = document.getElementById('fixNote').value.trim();
  if (!name || isNaN(amt) || amt <= 0) { toast('請填寫名稱與金額'); return; }
  fixItems.push({ name, amt, note });
  saveAll(); render(); closeSheet(); toast('固定支出已儲存');
}

function delIncItem(i) { incItems.splice(i,1); saveAll(); render(); }
function delFixItem(i) { fixItems.splice(i,1); saveAll(); render(); }
function delExp(i) { curExps().splice(i,1); saveAll(); render(); }

function closeSheet() {
  ['sh-income','sh-fix'].forEach(id => document.getElementById(id).classList.remove('on'));
  document.getElementById('overlay').classList.remove('on');
  document.getElementById('fab').classList.remove('open');
}

/* ── FAB ── */
function fabTap() {
  const cur = document.querySelector('.page.on').id;
  if (cur === 'pg-income') openSheet('income-add');
  else if (cur === 'pg-tracker') document.getElementById('qaAmt').focus();
  else if (cur === 'pg-settings') openSheet('fix-add');
  else openSheet('income-add');
}

/* ── Nav ── */
function navTo(name, idx) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.btab').forEach(b => b.classList.remove('on'));
  document.getElementById('pg-'+name).classList.add('on');
  document.getElementById('bt'+idx).classList.add('on');
  document.getElementById('scroller').scrollTop = 0;
  closeSheet();
}

/* ── Utils ── */
function fmt(n) { return (n<0?'-':'') + '$' + Math.abs(Math.round(n)).toLocaleString(); }
function fmtP(n) { return '$' + Math.round(Math.abs(n)).toLocaleString(); }
function fmtShort(n) {
  const a = Math.abs(Math.round(n));
  if (a >= 10000) return (n<0?'-':'') + '$' + (a/1000).toFixed(1) + 'k';
  return fmt(n);
}
function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('on');
  setTimeout(() => t.classList.remove('on'), 2000);
}
</script>
